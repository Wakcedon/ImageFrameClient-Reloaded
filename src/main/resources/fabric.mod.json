{
  "schemaVersion": 1,
  "id": "imageframeclient",
  "version": "${version}",
  "name": "ImageFrame Client",
  "description": "Complementary client mod for servers with ImageFrame to display HD and full color images!",
  "authors": ["LOOHP"],
  "license": "GPL-3.0",
  "icon": "assets/imageframeclient/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "com.loohp.imageframe.ImageFrameClient"
    ],
    "modmenu": [
      "com.loohp.imageframe.modmenu.ImageFrameClientModMenuApiImpl"
    ]
  },
  "mixins": [
    "imageframeclient.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.11",
    "fabric": "*",
    "minecraft": "~1.21",
    "java": ">=21"
  },
  "contact": {
    "homepage": "https://modrinth.com/mod/imageframeclient",
    "issues": "https://loohpjames.com/dev-discord",
    "sources": "https://github.com/LOOHP/ImageFrameClient"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.discord": "https://loohpjames.com/dev-discord",
        "modmenu.website": "https://modrinth.com/mod/imageframeclient"
      }
    }
  }
}
